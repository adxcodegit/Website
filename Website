*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{
  --cream:#F8F5EF;
  --ink:#0D1B2A;
  --muted:#5A6270;
  --rule:#E3DACE;
  --accent:#C8B99A;
  --accent-deep:#8C7355;
  --accent-light:#F5F0E6;
  --navy:#0D1B2A;
  --navy-mid:#1B3A5C;
  --sans:'DM Sans',sans-serif;
  --serif:'EB Garamond',Georgia,serif;
}
html{scroll-behavior:smooth;}
body{background:var(--cream);color:var(--ink);font-family:var(--sans);font-size:15px;line-height:1.7;-webkit-font-smoothing:antialiased;}
nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:0 3rem;height:60px;background:rgba(13,27,42,0.97);border-bottom:1px solid rgba(200,185,154,0.15);}
.nav-name{font-family:var(--serif);font-size:1.1rem;color:var(--accent);text-decoration:none;}
.nav-links{display:flex;gap:1.8rem;list-style:none;}
.nav-links a{font-size:0.72rem;letter-spacing:0.1em;text-transform:uppercase;color:rgba(255,255,255,0.45);text-decoration:none;transition:color 0.2s;}
.nav-links a:hover{color:var(--accent);}
#hero{min-height:100vh;display:flex;align-items:center;background:linear-gradient(135deg,#0D1B2A 0%,#1B3A5C 100%);padding:100px 0 4rem;}
.hero-inner{max-width:700px;margin:0 auto;padding:0 3rem;width:100%;}
.hero-eyebrow{font-size:0.75rem;letter-spacing:0.14em;text-transform:uppercase;color:var(--accent);margin-bottom:1.2rem;}
h1{font-family:var(--serif);font-size:clamp(3rem,7vw,5.5rem);font-weight:400;line-height:1.05;color:#fff;margin-bottom:1.5rem;}
h1 em{font-style:italic;color:var(--accent);}
.hero-sub{font-size:1.05rem;color:rgba(255,255,255,0.55);max-width:480px;line-height:1.75;margin-bottom:2.5rem;}
.hero-cta{display:flex;gap:0.9rem;flex-wrap:wrap;}
.btn{display:inline-flex;align-items:center;gap:0.4rem;padding:0.65rem 1.4rem;font-family:var(--sans);font-size:0.78rem;letter-spacing:0.06em;text-transform:uppercase;text-decoration:none;border-radius:2px;transition:all 0.2s;}
.btn-primary{background:var(--accent);color:var(--navy);border:1px solid var(--accent);font-weight:500;}
.btn-primary:hover{background:#b8a888;border-color:#b8a888;}
.btn-ghost{background:transparent;color:rgba(255,255,255,0.75);border:1px solid rgba(255,255,255,0.2);}
.btn-ghost:hover{border-color:var(--accent);color:var(--accent);}
section{max-width:900px;margin:0 auto;padding:5rem 3rem;border-top:1px solid var(--rule);}
.section-label{font-size:0.72rem;letter-spacing:0.14em;text-transform:uppercase;color:var(--accent-deep);margin-bottom:2.5rem;}
h2{font-family:var(--serif);font-size:clamp(1.8rem,3.5vw,2.6rem);font-weight:400;line-height:1.15;margin-bottom:1.5rem;}
.about-grid{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:start;}
.about-text p{color:var(--muted);margin-bottom:1rem;font-size:0.97rem;}
.about-stats{display:flex;flex-direction:column;gap:1.5rem;}
.stat-item{padding-bottom:1.5rem;border-bottom:1px solid var(--rule);}
.stat-item:last-child{border-bottom:none;padding-bottom:0;}
.stat-num{font-family:var(--serif);font-size:2.2rem;color:var(--navy-mid);line-height:1;margin-bottom:0.2rem;}
.stat-label{font-size:0.78rem;color:var(--muted);}
.exp-item{display:grid;grid-template-columns:200px 1fr;gap:2rem;padding:2rem 0;border-bottom:1px solid var(--rule);}
.exp-item:first-child{padding-top:0;}
.exp-item:last-child{border-bottom:none;}
.exp-dates{font-size:0.78rem;color:var(--muted);margin-bottom:0.3rem;}
.exp-company{font-size:0.8rem;font-weight:500;color:var(--accent-deep);}
.exp-location{font-size:0.75rem;color:var(--muted);margin-top:0.15rem;}
.exp-role{font-family:var(--serif);font-size:1.2rem;font-weight:400;margin-bottom:0.8rem;}
.exp-bullets{list-style:none;display:flex;flex-direction:column;gap:0.5rem;}
.exp-bullets li{font-size:0.9rem;color:var(--muted);padding-left:1.1rem;position:relative;line-height:1.65;}
.exp-bullets li::before{content:'--';position:absolute;left:0;color:var(--accent-deep);}
.edu-item{display:grid;grid-template-columns:200px 1fr;gap:2rem;padding:2rem 0;border-bottom:1px solid var(--rule);}
.edu-item:first-child{padding-top:0;}
.edu-item:last-child{border-bottom:none;}
.edu-year{font-size:0.78rem;color:var(--muted);padding-top:0.15rem;}
.edu-school{font-family:var(--serif);font-size:1.2rem;font-weight:400;margin-bottom:0.25rem;}
.edu-degree{font-size:0.85rem;color:var(--muted);margin-bottom:0.5rem;}
.edu-detail{font-size:0.82rem;color:var(--muted);line-height:1.6;}
.tag{display:inline-block;background:var(--accent-light);color:var(--accent-deep);font-size:0.7rem;padding:0.25rem 0.65rem;border-radius:2px;letter-spacing:0.04em;margin-top:0.5rem;}
.skills-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2rem;}
.skill-group-title{font-size:0.72rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--ink);margin-bottom:0.9rem;font-weight:500;}
.skill-group ul{list-style:none;display:flex;flex-direction:column;gap:0.45rem;}
.skill-group li{font-size:0.88rem;color:var(--muted);padding-left:0.9rem;position:relative;}
.skill-group li::before{content:'*';position:absolute;left:0;color:var(--accent-deep);}
.cert-list{display:flex;flex-direction:column;}
.cert-item{display:flex;align-items:flex-start;gap:1rem;padding:1rem 0;border-bottom:1px solid var(--rule);}
.cert-item:last-child{border-bottom:none;}
.cert-dot{width:6px;height:6px;min-width:6px;background:var(--accent-deep);border-radius:50%;margin-top:0.55rem;}
.cert-text{font-size:0.9rem;color:var(--muted);line-height:1.6;}
.cert-text strong{color:var(--ink);font-weight:500;}
.projects-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:2rem;}
.project-card{background:#fff;border:1px solid var(--rule);padding:1.6rem;border-radius:3px;transition:border-color 0.2s,box-shadow 0.2s;}
.project-card:hover{border-color:var(--navy-mid);box-shadow:0 4px 20px rgba(13,27,42,0.07);}
.project-ticker{font-size:0.7rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--accent-deep);margin-bottom:0.6rem;}
.project-title{font-family:var(--serif);font-size:1.15rem;font-weight:400;margin-bottom:0.6rem;}
.project-desc{font-size:0.87rem;color:var(--muted);line-height:1.65;}
.project-tags{margin-top:1rem;display:flex;gap:0.4rem;flex-wrap:wrap;}
.project-btn{display:inline-flex;align-items:center;gap:0.35rem;margin-top:1.1rem;padding:0.45rem 1rem;font-family:var(--sans);font-size:0.72rem;letter-spacing:0.07em;text-transform:uppercase;text-decoration:none;border:1px solid var(--rule);border-radius:2px;color:var(--accent-deep);background:transparent;transition:border-color 0.2s,background 0.2s;}
.project-btn:hover{border-color:var(--accent-deep);background:var(--accent-light);}
.report-item{display:flex;align-items:center;justify-content:space-between;padding:1.4rem 0;border-bottom:1px solid var(--rule);gap:1.5rem;}
.report-item:first-child{border-top:1px solid var(--rule);}
.report-type{font-size:0.7rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--accent-deep);margin-bottom:0.25rem;}
.report-title{font-family:var(--serif);font-size:1.05rem;font-weight:400;color:var(--ink);}
.report-btn{display:inline-flex;align-items:center;gap:0.4rem;padding:0.5rem 1.1rem;font-size:0.72rem;letter-spacing:0.07em;text-transform:uppercase;text-decoration:none;border:1px solid var(--rule);border-radius:2px;color:var(--ink);background:#fff;white-space:nowrap;transition:border-color 0.2s,background 0.2s;flex-shrink:0;}
